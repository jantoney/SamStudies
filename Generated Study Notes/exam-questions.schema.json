                ],
                "properties": {
                  "blank_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "accepted_answers": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },
    "clozeQuestion": {
