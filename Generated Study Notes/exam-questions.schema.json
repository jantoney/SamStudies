{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/exam-questions.schema.json",
  "title": "Exam Prep Question Set",
  "description": "JSON Schema for generated exam-prep question documents. Supports the current single-choice format with keyed options and keyed answers, plus common future exam formats such as multiple-select, true/false, short answer, matching, ordering, cloze, essay, extended matching, and data-interpretation questions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "resource_type",
    "title",
    "slug",
    "chapter",
    "description",
    "disclaimer",
    "source_notes",
    "format",
    "questions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "resource_type": {
      "const": "exam_prep_question_set"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "chapter": {
      "$ref": "#/$defs/chapter"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "disclaimer": {
      "$ref": "#/$defs/disclaimer"
    },
    "source_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceNote"
      }
    },
    "format": {
      "$ref": "#/$defs/format"
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/question"
      }
    }
  },
  "$defs": {
    "chapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "number",
        "code",
        "title",
        "status"
      ],
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "code": {
          "type": "string",
          "pattern": "^[0-9]{2}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "planned",
            "in_progress",
            "complete"
          ]
        }
      }
    },
    "disclaimer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "endorsement_notice"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "endorsement_notice": {
          "type": "string",
          "minLength": 1
        },
        "answer_key_note": {
          "type": "string"
        }
      }
    },
    "sourceNote": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "source_title"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "minLength": 1
        },
        "source_title": {
          "type": "string",
          "minLength": 1
        },
        "organization": {
          "type": "string"
        },
        "publisher": {
          "type": "string"
        },
        "edition": {
          "type": "string"
        },
        "publication_year": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 9999
        },
        "reference_note": {
          "type": "string"
        }
      }
    },
    "format": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question_count",
        "question_type",
        "answer_key_included"
      ],
      "properties": {
        "question_count": {
          "type": "integer",
          "minimum": 1
        },
        "question_type": {
          "enum": [
            "single_choice",
            "multiple_select",
            "true_false",
            "short_answer",
            "fill_in_blank",
            "cloze",
            "matching",
            "ordering",
            "extended_matching",
            "essay",
            "data_interpretation",
            "mixed"
          ]
        },
        "choices_distribution": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[0-9]+$"
          },
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "answer_key_included": {
          "type": "boolean"
        },
        "answer_format": {
          "type": "string",
          "description": "Describes how answers are encoded, for example correct_choice_key_with_reason."
        },
        "choice_keys_included": {
          "type": "boolean"
        },
        "choice_key_format": {
          "type": "string"
        },
        "choice_order_randomizable": {
          "type": "boolean"
        },
        "page_reference_style": {
          "type": "string"
        }
      }
    },
    "questionBase": {
      "type": "object",
      "required": [
        "number",
        "question_id",
        "type",
        "question"
      ],
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "question_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string"
        },
        "question": {
          "type": "string",
          "minLength": 1
        },
        "stem": {
          "type": "string"
        },
        "instructions": {
          "type": "string"
        },
        "difficulty": {
          "enum": [
            "easy",
            "medium",
            "hard"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "answer_explanation": {
          "type": "string"
        }
      }
    },
    "choiceArray": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/choice"
      }
    },
    "singleChoiceAnswer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correct_choice_key"
      ],
      "properties": {
        "correct_choice_key": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "source_page_refs": {
          "$ref": "#/$defs/pageRefArray"
        }
      }
    },
    "singleChoiceQuestion": {
      "allOf": [
        {
          "$ref": "#/$defs/questionBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "number",
            "question_id",
            "type",
            "question",
            "choices"
          ],
          "properties": {
            "number": {
              "type": "integer",
              "minimum": 1
            },
            "question_id": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "const": "single_choice"
            },
            "question": {
              "type": "string",
              "minLength": 1
            },
            "stem": {
              "type": "string"
            },
            "instructions": {
              "type": "string"
            },
            "difficulty": {
              "enum": [
                "easy",
                "medium",
                "hard"
              ]
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "answer_explanation": {
              "type": "string"
            },
            "choices": {
              "$ref": "#/$defs/choiceArray"
            },
            "answer": {
              "$ref": "#/$defs/singleChoiceAnswer"
            }
          }
        }
      ]
    },
    "multipleSelectQuestion": {
      "allOf": [
        {
          "$ref": "#/$defs/questionBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "number",
            "question_id",
            "type",
            "question",
            "choices"
          ],
          "properties": {
            "number": {
              "type": "integer",
              "minimum": 1
            },
            "question_id": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "const": "multiple_select"
            },
            "question": {
              "type": "string",
              "minLength": 1
            },
            "stem": {
              "type": "string"
            },
            "instructions": {
              "type": "string"
            },
            "difficulty": {
              "enum": [
                "easy",
                "medium",
                "hard"
              ]
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "answer_explanation": {
              "type": "string"
            },
            "choices": {
              "$ref": "#/$defs/choiceArray"
            },
            "answer": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "correct_choice_keys"
              ],
              "properties": {
                "correct_choice_keys": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "uniqueItems": true
                },
                "reason": {
                  "type": "string",
                  "minLength": 1
                },
                "source_page_refs": {
                  "$ref": "#/$defs/pageRefArray"
                }
              }
            }
          }
        }
      ]
    },
    "trueFalseQuestion": {
      "allOf": [
