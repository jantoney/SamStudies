              "type": "string"
            },
            "choices": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": {
                "enum": [
                  "True",
                  "False"
                ]
              }
            },
            "answer": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "correct_value"
              ],
              "properties": {
                "correct_value": {
                  "type": "boolean"
                },
                "reason": {
                  "type": "string",
                  "minLength": 1
                },
                "source_page_refs": {
                  "$ref": "#/$defs/pageRefArray"
                }
              }
            }
          }
        }
      ]
    },
    "shortAnswerQuestion": {
