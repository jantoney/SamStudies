                },
                "reason": {
                  "type": "string",
                  "minLength": 1
                },
                "source_page_refs": {
                  "$ref": "#/$defs/pageRefArray"
                }
              }
            }
          }
        }
      ]
    },
    "dataInterpretationQuestion": {
      "allOf": [
        {
          "$ref": "#/$defs/questionBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "number",
            "question_id",
            "type",
            "question",
            "stimulus"
          ],
          "properties": {
            "number": {
              "type": "integer",
              "minimum": 1
            },
            "question_id": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "const": "data_interpretation"
            },
            "question": {
              "type": "string",
              "minLength": 1
            },
            "stem": {
              "type": "string"
            },
            "instructions": {
              "type": "string"
            },
            "difficulty": {
              "enum": [
                "easy",
                "medium",
                "hard"
              ]
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "answer_explanation": {
              "type": "string"
            },
            "stimulus": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "stimulus_type",
                "content"
              ],
              "properties": {
                "stimulus_type": {
                  "enum": [
                    "table",
                    "chart",
                    "graph",
                    "image",
                    "case_data",
                    "mixed"
                  ]
                },
                "content": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "choices": {
              "$ref": "#/$defs/choiceArray"
            },
            "answer": {
              "oneOf": [
                {
                  "$ref": "#/$defs/singleChoiceAnswer"
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "accepted_answers"
                  ],
                  "properties": {
                    "accepted_answers": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "reason": {
                      "type": "string",
                      "minLength": 1
                    },
                    "source_page_refs": {
                      "$ref": "#/$defs/pageRefArray"
                    }
                  }
                }
              ]
            }
          }
        }
      ]
    },
    "question": {
      "oneOf": [
        {
          "$ref": "#/$defs/singleChoiceQuestion"
        },
        {
          "$ref": "#/$defs/multipleSelectQuestion"
        },
        {
          "$ref": "#/$defs/trueFalseQuestion"
        },
        {
          "$ref": "#/$defs/shortAnswerQuestion"
        },
        {
          "$ref": "#/$defs/fillInBlankQuestion"
        },
        {
          "$ref": "#/$defs/clozeQuestion"
        },
        {
          "$ref": "#/$defs/matchingQuestion"
        },
        {
          "$ref": "#/$defs/orderingQuestion"
        },
        {
          "$ref": "#/$defs/extendedMatchingQuestion"
        },
        {
          "$ref": "#/$defs/essayQuestion"
        },
        {
          "$ref": "#/$defs/dataInterpretationQuestion"
        }
      ]
    },
    "pageRefArray": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1
      },
      "uniqueItems": true
    },
    "choice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "text"
      ],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
